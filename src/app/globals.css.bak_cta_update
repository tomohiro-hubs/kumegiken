}

.area__ctaWrap {
  margin-top: 36px;
  display: flex;
  justify-content: center;
}

.area__cta {
  min-width: 320px;
}

@media (hover: hover) and (pointer: fine) {
  .area__tag {
    transition: transform var(--transition), border-color var(--transition);
  }

  .area__tag:hover {
    transform: translateY(-2px);
    border-color: #bfc9d9;
  }
