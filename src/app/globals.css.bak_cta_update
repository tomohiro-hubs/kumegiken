/* --- CTA v2 (Homepage) --- */
.cta-v2 {
  padding: 0;
  background: transparent;
}

.cta-v2__shell {
  width: 100vw;
  max-width: 100vw;
  margin: 0 calc(50% - 50vw);
  border-radius: 0;
  overflow: hidden;
  box-shadow: none;
  border: 0;
}

.cta-v2__top {
  position: relative;
  padding: 40px 52px 22px;
  background: var(--cta-v2-bg-image, url("/images/footer-cta-bg.png"));
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  color: var(--color-white);
  text-align: center;
}

.cta-v2__top::after {
  content: none;
}

.cta-v2__title {
  font-size: 28px;
  line-height: 1.2;
  letter-spacing: 0.02em;
  font-weight: var(--fw-black);
  margin-bottom: 8px;
}

.cta-v2__title-accent {
  color: #ff9d00;
  margin: 0 8px;
  display: inline-block;
}

.cta-v2__subtext {
  font-size: 14px;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.78);
  margin-bottom: 28px;
}

.cta-v2__actions {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 22px;
  align-items: stretch;
  max-width: 1200px;
  margin: 0 auto 20px;
}

.cta-v2__action {
  min-height: 88px;
  border-radius: 18px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-weight: var(--fw-bold);
  transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition), background-color var(--transition);
}

.cta-v2__action--phone {
  justify-content: center;
  gap: 14px;
  padding: 12px 18px 12px 24px;
  color: var(--color-white);
  border: 0;
  background: transparent;
  box-shadow: none;
}

.cta-v2__phone-icon {
  width: 70px;
  height: 70px;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.65);
  background: #fff;
  color: #0f2145;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 34px;
  flex-shrink: 0;
}

.cta-v2__phone-icon .fa-phone-alt {
  transform: scaleX(-1);
}

.cta-v2__phone-copy {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  line-height: 1.2;
}

.cta-v2__phone-label {
  font-size: 14px;
  font-weight: var(--fw-bold);
  letter-spacing: 0.02em;
  color: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(255,255,255,0.5);
  border-radius: 3px;
  padding: 4px 10px;
}

.cta-v2__phone-number {
  margin-top: 10px;
  font-family: var(--font-en);
  font-size: 26px;
  letter-spacing: 0.03em;
  font-weight: var(--fw-black);
  color: #ffffff;
  line-height: 1;
}

.cta-v2__action--primary {
  border: 1px solid #ff973a;
  color: var(--color-white);
  background: linear-gradient(180deg, #ff9b3f 0%, #ee6f08 100%);
  box-shadow: 0 14px 28px rgba(230, 111, 8, 0.36);
  font-size: 18px;
  justify-content: center;
  padding: 10px 22px 10px 20px;
  text-align: center;
  position: relative;
  left: -20px;
}

.cta-v2__primary-copy {
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1;
}

.cta-v2__primary-sub {
  font-size: 12px;
  font-weight: var(--fw-bold);
  letter-spacing: 0.02em;
  opacity: 0.98;
  margin-bottom: 7px;
}

.cta-v2__primary-main {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 18px;
  font-weight: var(--fw-black);
  line-height: 1.05;
}

.cta-v2__primary-arrow {
  position: absolute;
  right: 18px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 34px;
  font-weight: var(--fw-bold);
  line-height: 1;
}

.cta-v2__action--secondary {
  border: 3px solid rgba(255, 255, 255, 0.8);
  color: var(--color-white);
  background: rgba(255, 255, 255, 0.02);
  font-size: 18px;
  gap: 10px;
  position: relative;
  left: -20px;
}

.cta-v2__reassurance {
  font-size: 13px;
  letter-spacing: 0.03em;
  color: rgba(255, 255, 255, 0.82);
}

.cta-v2__reassurance-accent {
  color: #ffb267;
  font-weight: var(--fw-bold);
}

.cta-v2__mid {
  background: var(--color-white);
  border-top: 1px solid rgba(212, 221, 236, 0.92);
  border-bottom: 1px solid rgba(212, 221, 236, 0.92);
  padding: 34px 56px;
}

.cta-v2__features {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16px;
}

.cta-v2__feature {
  min-height: 92px;
  padding: 14px 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  color: #1d2e4d;
  font-weight: var(--fw-bold);
  font-size: 17px;
  border-radius: 10px;
  border: 1px solid #dce5f2;
  background: #f9fbff;
}

.cta-v2__feature-badge {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  border: 1px solid #cfdcf0;
  color: #dd7b1e;
  background: #ffffff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  box-shadow: 0 4px 12px rgba(26, 39, 68, 0.08);
  flex-shrink: 0;
}

.cta-v2__bottom {
  background: linear-gradient(180deg, #111f3a 0%, #0e172c 100%);
  color: var(--color-white);
  text-align: center;
  padding: 28px 24px 30px;
}

.cta-v2__bottom-text {
  font-size: 30px;
  line-height: 1.45;
  letter-spacing: 0.02em;
  font-weight: var(--fw-bold);
}

.cta-v2__bottom-highlight {
  font-family: var(--font-en);
  font-size: 54px;
  line-height: 1;
  font-weight: var(--fw-black);
  letter-spacing: 0.03em;
  color: #ffb262;
  text-shadow: 0 2px 14px rgba(255, 153, 64, 0.28);
