}

@media (hover: hover) and (pointer: fine) {
  .cta-v2__action:hover {
    transform: translateY(-2px);
  }

  .cta-v2__action--primary:hover {
    box-shadow: 0 18px 32px rgba(230, 111, 8, 0.44);
  }

  .cta-v2__action--secondary:hover,
  .cta-v2__action--phone:hover {
