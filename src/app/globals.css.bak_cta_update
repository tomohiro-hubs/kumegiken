  color: var(--color-primary);
  margin-bottom: 8px;
}

.service-card__text {
  font-size: 13px;
  color: var(--color-text-light);
  line-height: 1.8;
  margin-bottom: 16px;
}

.service-card__link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  font-weight: var(--fw-bold);
  color: var(--color-accent);
}

.service-card__link:hover {
  gap: 10px;
}

/* --- Works Section --- */
.works {
  padding: var(--section-padding);
}

.works__filter {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-bottom: 40px;
  flex-wrap: wrap;
}

.works__filter-btn {
  padding: 8px 20px;
  font-size: 13px;
  font-weight: var(--fw-medium);
  color: var(--color-text-light);
  border: 1px solid var(--color-border);
  border-radius: 50px;
  transition: var(--transition);
  cursor: pointer;
  background: var(--color-white);
}

.works__filter-btn:hover,
.works__filter-btn.active {
  background: var(--color-primary);
  color: var(--color-white);
  border-color: var(--color-primary);
}

.works__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.works__featureBanner {
  position: relative;
  overflow: hidden;
}

.works__featureOverlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 56px 24px;
  z-index: 2;
}

.works__featureHeading {
  margin: 0;
}

.works__featureFade {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(90deg, rgba(242, 246, 251, 0.98) 0%, rgba(242, 246, 251, 0.92) 52%, rgba(242, 246, 251, 0) 100%);
}

.works__featureCopy {
  position: static;
  width: min(92vw, 860px);
  padding: 0;
  margin: 65px 0 0;
  font-size: 18px;
  line-height: 1.9;
  font-weight: var(--fw-medium);
  color: #1d355d;
  text-align: center;
}

.work-card {
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--color-white);
  box-shadow: var(--shadow-sm);
  transition: var(--transition);
}

.work-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
}

.work-card__image {
  position: relative;
  aspect-ratio: 3/2;
  overflow: hidden;
}

.work-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: var(--transition-slow);
}

.work-card:hover .work-card__image img {
  transform: scale(1.05);
}

.work-card__category {
  position: absolute;
  top: 12px;
  left: 12px;
  background: var(--color-accent);
  color: var(--color-white);
  font-size: 11px;
  font-weight: var(--fw-bold);
  padding: 4px 12px;
  border-radius: 3px;
}

.work-card__body {
  padding: 20px;
}

.work-card__meta {
  display: flex;
  gap: 12px;
  margin-bottom: 8px;
}

.work-card__meta-item {
  font-size: 12px;
  color: var(--color-text-muted);
}

.work-card__title {
  font-size: 15px;
  font-weight: var(--fw-bold);
  color: var(--color-primary);
  line-height: 1.5;
}

.work-card__estimate {
  margin-top: 8px;
  font-size: 13px;
  color: var(--color-text-muted);
}

/* --- Flow Section --- */
.flow {
  padding: var(--section-padding);
  background: var(--color-bg-light);
}

.flow__timeline {
  position: relative;
  max-width: 1140px;
  margin: 0 auto;
  padding-left: 18px;
}

.flow__timeline::before {
  content: '';
  position: absolute;
  left: 50px;
  top: 28px;
  bottom: 28px;
  width: 2px;
  background: repeating-linear-gradient(
    to bottom,
    #9fb0c9 0 2px,
    transparent 2px 6px
  );
}

.flow__step {
  position: relative;
  padding: 0 0 10px 0;
  margin-bottom: 10px;
}

.flow__step:last-child {
  margin-bottom: 0;
}

.flow__card {
  margin-left: 18px;
  display: grid;
  grid-template-columns: 1fr minmax(240px, 34%);
  align-items: stretch;
  min-height: 200px;
  height: 200px;
  background: var(--color-white);
  border: 1px solid #dce3ee;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 1px 0 rgba(9, 24, 48, 0.03);
  position: relative;
}

.flow__step-number {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translate(-10px, -50%);
  z-index: 2;
  width: 60px;
  height: 60px;
  background: var(--color-primary);
  color: var(--color-white);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-en);
  font-size: 18px;
  font-weight: var(--fw-bold);
  box-shadow: 0 10px 18px rgba(8, 30, 68, 0.18);
}

.flow__step--highlight .flow__step-number {
  background: var(--color-accent);
  box-shadow: 0 10px 18px rgba(245, 117, 5, 0.28);
}

.flow__step-content {
  padding: 26px 30px 24px 98px;
}

.flow__step-title {
  font-size: 24px;
  font-weight: var(--fw-bold);
  color: var(--color-primary);
  margin-bottom: 10px;
  letter-spacing: 0.02em;
}

.flow__step--highlight .flow__step-title {
  color: var(--color-accent);
}

.flow__step-text {
  font-size: 14px;
  color: #263a5e;
  line-height: 1.85;
  margin: 0;
}

.flow__step-image {
  min-height: 200px;
  height: 200px;
}

.flow__step-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* --- Voice Section --- */
.voice {
  padding: var(--section-padding);
}

.voice-carousel {
  --voice-gap: 30px;
}

.voice-carousel__header {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 24px;
}

.voice-carousel__controls {
  display: flex;
  gap: 12px;
}

.voice-carousel__button {
  width: 52px;
  height: 52px;
  border: 1px solid var(--color-border);
  border-radius: 50%;
  background: var(--color-white);
  color: var(--color-primary);
  font-size: 20px;
  font-weight: var(--fw-bold);
  transition: var(--transition);
}

.voice-carousel__button:hover {
  background: var(--color-primary);
  color: var(--color-white);
  border-color: var(--color-primary);
}

.voice-carousel__viewport {
  overflow: hidden;
}

.voice-carousel__track {
  display: flex;
  gap: var(--voice-gap);
  transition: transform var(--transition-slow);
  will-change: transform;
}

.voice-card {
  flex: 0 0 calc((100% - var(--voice-gap)) / 2);
  background: var(--color-white);
  border: 1px solid var(--color-border-light);
  border-radius: var(--radius-lg);
  padding: 36px;
  transition: var(--transition);
}

.voice-card:hover {
  box-shadow: var(--shadow-md);
}

.voice-card__stars {
  color: var(--color-accent);
  font-size: 16px;
  margin-bottom: 12px;
  letter-spacing: 2px;
}

.voice-card__text {
  font-size: 15px;
  line-height: 2;
  color: var(--color-text);
  margin-bottom: 20px;
}

.voice-card__author {
  display: flex;
  align-items: center;
  gap: 16px;
}

.voice-card__avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: var(--color-bg-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: var(--fw-bold);
  color: var(--color-primary);
}

.voice-card__info {
  font-size: 13px;
}

.voice-card__name {
  font-weight: var(--fw-bold);
  color: var(--color-primary);
}

.voice-card__detail {
  color: var(--color-text-muted);
  margin-top: 2px;
}

.voice-carousel__dots {
  display: flex;
  justify-content: center;
  gap: 10px;
  margin-top: 28px;
}

.voice-carousel__dot {
  width: 44px;
  height: 44px;
  min-width: 44px;
  min-height: 44px;
  border-radius: 999px;
  background: transparent;
  position: relative;
  transition: var(--transition);
}

.voice-carousel__dot::before {
  content: "";
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: rgba(26, 39, 68, 0.42);
  position: absolute;
  inset: 50% auto auto 50%;
  transform: translate(-50%, -50%);
}

.voice-carousel__dot.is-active {
  background: transparent;
}

.voice-carousel__dot.is-active::before {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--color-accent);
}

/* --- Message Section (CEO) --- */
.message {
  padding: var(--section-padding);
  background: var(--color-primary);
  color: var(--color-white);
  position: relative;
  overflow: hidden;
}

.message__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}

.message__image {
  border-radius: var(--radius-lg);
  overflow: hidden;
  aspect-ratio: 3/4;
}

.message__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.message__content {
  padding: 20px 0;
}

.message__label {
  font-family: var(--font-en);
  font-size: 13px;
  font-weight: var(--fw-semibold);
  letter-spacing: 0.15em;
  color: var(--color-accent);
  text-transform: uppercase;
  margin-bottom: 12px;
}

.message__title {
  font-size: 28px;
  font-weight: var(--fw-bold);
  line-height: 1.6;
  margin-bottom: 24px;
}

.message__text {
  font-size: 15px;
  line-height: 2.2;
  color: rgba(255,255,255,0.8);
  margin-bottom: 30px;
}

.message__name {
  text-align: right;
}

.message__name-title {
  font-size: 12px;
  color: rgba(255,255,255,0.6);
}

.message__name-value {
  font-size: 20px;
  font-weight: var(--fw-bold);
  margin-top: 4px;
}

/* --- Area Section --- */
.area {
  padding: var(--section-padding);
  background: var(--color-bg-light);
}

.area__container {
  max-width: 1120px;
}

.area .section-heading {
  margin-bottom: 16px;
}

.area__title {
  text-align: center;
  font-size: clamp(24px, 2.6vw, 32px);
  line-height: 1.35;
  color: var(--color-primary);
  margin: 0;
}

.area__intro {
  text-align: center;
  font-size: 16px;
  line-height: 2;
  color: var(--color-text-light);
  margin: 18px auto 40px;
}

.area__mapCard {
  border: 1px solid #dbe2ee;
  border-radius: 24px;
  aspect-ratio: 16 / 6.6;
  overflow: hidden;
}

.area__mapImage {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

.area__label {
  margin: 36px auto 24px;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20px;
}

.area__labelLine {
  width: 56px;
  height: 1px;
  background: rgba(26, 39, 68, 0.75);
}

.area__labelText {
  font-size: 18px;
  font-weight: var(--fw-bold);
  color: var(--color-primary);
  letter-spacing: 0.04em;
}

.area__list {
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  gap: 12px;
}

.area__tag {
  display: inline-flex;
  justify-content: center;
  align-items: center;
  min-height: 56px;
  padding: 0 14px;
  background: var(--color-white);
  border: 1px solid #d1d8e4;
  border-radius: 50px;
  font-size: 16px;
  font-weight: var(--fw-medium);
  color: var(--color-text);
}

.area__tag--active {
  background: var(--color-primary);
  color: var(--color-white);
  border-color: var(--color-primary);
}

.area__featureVisual {
  position: relative;
  height: 400px;
  border-radius: 16px;
  overflow: hidden;
}

.area__featureImage {
  width: 100%;
  height: 400px;
  object-fit: cover;
  object-position: center;
  display: block;
}

.area__featureFade {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(242, 246, 251, 0.98) 0%, rgba(242, 246, 251, 0.92) 52%, rgba(242, 246, 251, 0) 100%);
