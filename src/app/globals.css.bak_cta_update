/* ============================================
   久米技建 - メインスタイルシート
   Design: ダークネイビー × ホワイト × アクセントオレンジ
   Font: Noto Sans JP + Inter
   ============================================ */

/* --- CSS Custom Properties --- */
:root {
  /* Colors */
  --color-primary: #1A2744;
  --color-primary-light: #253559;
  --color-primary-dark: #111B30;
  --color-accent: #E8740C;
  --color-accent-hover: #D16508;
  --color-accent-light: rgba(232, 116, 12, 0.1);
  --color-white: #FFFFFF;
  --color-bg: #FFFFFF;
  --color-bg-light: #F7F8FA;
  --color-bg-gray: #F0F2F5;
  --color-text: #333333;
  --color-text-light: #666666;
  --color-text-muted: #999999;
  --color-border: #E0E3E8;
  --color-border-light: #ECEEF2;

  /* Typography */
  --font-ja: var(--font-ja-next), 'Noto Sans JP', 'Hiragino Kaku Gothic ProN', 'Yu Gothic', sans-serif;
  --font-en: var(--font-ja-next), 'Noto Sans JP', 'Hiragino Kaku Gothic ProN', 'Yu Gothic', sans-serif;
  --fw-light: 300;
  --fw-regular: 400;
  --fw-medium: 500;
  --fw-semibold: 600;
  --fw-bold: 700;
  --fw-black: 900;

  /* Spacing */
  --section-padding: 100px 0;
  --section-padding-sm: 60px 0;
  --container-width: 1200px;
  --container-narrow: 900px;
  --gap: 24px;
  --gap-lg: 40px;
  --gap-xl: 60px;

  /* Borders & Radius */
  --radius: 8px;
  --radius-lg: 16px;
  --radius-xl: 24px;

  /* Shadows */
  --shadow-sm: 0 2px 8px rgba(26, 39, 68, 0.06);
  --shadow-md: 0 4px 20px rgba(26, 39, 68, 0.08);
  --shadow-lg: 0 8px 40px rgba(26, 39, 68, 0.12);
  --shadow-xl: 0 16px 60px rgba(26, 39, 68, 0.16);

  /* Transitions */
  --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-slow: 0.6s cubic-bezier(0.4, 0, 0.2, 1);

  /* Header */
  --header-height: 80px;
}

/* --- Reset & Base --- */
*, *::before, *::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  font-size: 16px;
  scroll-behavior: smooth;
  -webkit-text-size-adjust: 100%;
}

body {
  font-family: var(--font-ja);
  font-weight: var(--fw-regular);
  color: var(--color-text);
  background: var(--color-bg);
  line-height: 1.8;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

img {
  max-width: 100%;
  height: auto;
  display: block;
}

a {
  color: inherit;
  text-decoration: none;
  transition: var(--transition);
}

ul, ol {
  list-style: none;
}

button {
  cursor: pointer;
  border: none;
  background: none;
  font-family: inherit;
}

input, textarea, select {
  font-family: inherit;
  font-size: inherit;
}

/* --- Utility Classes --- */
.container {
  width: 100%;
  max-width: var(--container-width);
  margin: 0 auto;
  padding: 0 24px;
}

.container--narrow {
  max-width: var(--container-narrow);
}

.en {
  font-family: var(--font-en);
}

.text-accent {
  color: var(--color-accent);
}

.text-primary {
  color: var(--color-primary);
}

.bg-primary {
  background-color: var(--color-primary);
  color: var(--color-white);
}

.bg-light {
  background-color: var(--color-bg-light);
}

.bg-gray {
  background-color: var(--color-bg-gray);
}

/* --- Section Heading --- */
.section-heading {
  text-align: center;
  margin-bottom: 60px;
}

.section-heading__en {
  font-family: var(--font-en);
  font-size: 14px;
  font-weight: var(--fw-semibold);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--color-accent);
  display: block;
  margin-bottom: 8px;
}

.section-heading__ja {
  font-size: 32px;
  font-weight: var(--fw-bold);
  line-height: 1.4;
  color: var(--color-primary);
}

.section-heading__line {
  display: block;
  width: 40px;
  height: 3px;
  background: var(--color-accent);
  margin: 16px auto 0;
}

.section-heading--white .section-heading__ja {
  color: var(--color-white);
}

.section-heading--white .section-heading__en {
  color: rgba(255,255,255,0.6);
}

.section-heading--left {
  text-align: left;
}

.section-heading--left .section-heading__line {
  margin-left: 0;
}

.section-intro {
  text-align: center;
  max-width: 920px;
  margin: 0 auto 24px;
  color: var(--color-text-light);
  line-height: 1.9;
}

.section-chip-links {
  display: flex;
  justify-content: center;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 28px;
}

.section-stack {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.section-more {
  text-align: center;
  margin-top: 48px;
}

/* --- Buttons --- */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 16px 36px;
  font-size: 15px;
  font-weight: var(--fw-bold);
  border-radius: 50px;
  transition: var(--transition);
  letter-spacing: 0.05em;
  position: relative;
  overflow: hidden;
}

.btn--primary {
  background: var(--color-accent);
  color: var(--color-white);
  box-shadow: 0 4px 16px rgba(232, 116, 12, 0.3);
}

.btn--primary:hover {
  background: var(--color-accent-hover);
  transform: translateY(-2px);
  box-shadow: 0 6px 24px rgba(232, 116, 12, 0.4);
}

.btn--outline {
  background: transparent;
  color: var(--color-white);
  border: 2px solid var(--color-white);
}

.btn--outline:hover {
  background: var(--color-white);
  color: var(--color-primary);
}

.btn--outline-dark {
  background: transparent;
  color: var(--color-primary);
  border: 2px solid var(--color-primary);
}

.btn--outline-dark:hover {
  background: var(--color-primary);
  color: var(--color-white);
}

.btn--white {
  background: var(--color-white);
  color: var(--color-primary);
}

.btn--white:hover {
  background: var(--color-bg-light);
  transform: translateY(-2px);
}

.btn--lg {
  padding: 20px 48px;
  font-size: 17px;
}

.btn--sm {
  padding: 10px 24px;
  font-size: 13px;
}

.btn__arrow {
  transition: transform var(--transition);
}

.btn:hover .btn__arrow {
  transform: translateX(4px);
}

/* --- top-copy2: Uchida reference reproduction --- */
.uchida-reference-header {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 1200;
  display: grid;
  grid-template-columns: 1fr auto 72px;
  width: 100%;
  height: 72px;
  border-bottom: 1px solid #171717;
  background: rgba(222, 223, 211, 0.94);
  backdrop-filter: blur(8px);
}

.uchida-reference-header__brand,
.uchida-reference-header__cta,
.uchida-reference-header__menu {
  display: flex;
  align-items: center;
  color: #111;
}

.uchida-reference-header__brand {
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  padding-left: 40px;
  font-family: var(--font-ja);
}

.uchida-reference-header__brand span {
  font-size: 22px;
  line-height: 1.1;
}

.uchida-reference-header__brand small {
  margin-top: 5px;
  font-family: var(--font-ja);
  font-size: 10px;
}

.uchida-reference-header__cta {
  align-self: center;
  justify-content: center;
  min-width: 178px;
  height: 48px;
  padding: 0 28px;
  border-radius: 999px;
  background: #000;
  color: #fff;
  font-size: 13px;
  font-weight: 500;
  gap: 12px;
}

.uchida-reference-header__menu {
  justify-content: center;
  flex-direction: column;
  gap: 7px;
  border-left: 1px solid #171717;
}

.uchida-reference-header__menu span {
  width: 32px;
  height: 1px;
  background: #111;
}

.uchida-reference-footer {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 48px;
  padding: 56px 72px 32px;
  border-top: 1px solid rgba(17, 17, 17, 0.35);
  background: #dedfd3;
  color: #111;
}

.uchida-reference-footer__brand {
  font-family: var(--font-ja);
}

.uchida-reference-footer__brand span,
.uchida-reference-footer__brand small {
  display: block;
}

.uchida-reference-footer__brand span {
  font-size: 24px;
  line-height: 1.2;
}

.uchida-reference-footer__brand small {
  margin-top: 6px;
  font-family: var(--font-ja);
  font-size: 10px;
}

.uchida-reference-footer nav {
  display: grid;
  grid-template-columns: repeat(3, minmax(140px, 1fr));
  gap: 18px 32px;
}

.uchida-reference-footer a {
  color: #111;
  font-size: 14px;
}

.uchida-reference-footer p {
  grid-column: 1 / -1;
  padding-top: 28px;
  border-top: 1px solid rgba(17, 17, 17, 0.25);
  font-size: 12px;
  color: rgba(17, 17, 17, 0.64);
}

.uchida-copy {
  --uchida-paper: #dedfd3;
  --uchida-line: rgba(17, 17, 17, 0.18);
  --uchida-ink: #111;
  --uchida-muted: rgba(17, 17, 17, 0.58);
  margin-top: 72px;
  background:
    radial-gradient(circle at 22% 18%, rgba(255, 255, 255, 0.38), transparent 28%),
    radial-gradient(circle at 78% 62%, rgba(110, 115, 96, 0.12), transparent 28%),
    linear-gradient(90deg, var(--uchida-line) 1px, transparent 1px),
    linear-gradient(0deg, rgba(17, 17, 17, 0.08) 1px, transparent 1px),
    var(--uchida-paper);
  background-size: auto, auto, 180px 180px, 180px 180px, auto;
  color: var(--uchida-ink);
  font-family: var(--font-ja);
}

.uchida-copy img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.uchida-hero {
  display: grid;
  grid-template-columns: 35% 30% 35%;
  min-height: calc(100svh - 72px - 64px);
  border-bottom: 1px solid #171717;
  overflow: hidden;
}

.uchida-hero__left {
  border-right: 1px solid #171717;
  min-height: 560px;
}

.uchida-hero__center {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 560px;
  background:
    radial-gradient(circle at 50% 48%, rgba(255, 255, 255, 0.34), transparent 36%),
    linear-gradient(90deg, rgba(17, 17, 17, 0.12) 1px, transparent 1px),
    linear-gradient(0deg, rgba(17, 17, 17, 0.08) 1px, transparent 1px);
  background-size: auto, 90px 90px, 90px 90px;
}

.uchida-hero__mark {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 38px;
  font-family: var(--font-ja);
  font-weight: 400;
}

.uchida-hero__mark span {
  display: block;
  padding: 10px 13px;
  border: 1px solid rgba(17, 17, 17, 0.58);
  font-size: clamp(34px, 3.5vw, 52px);
  line-height: 1.35;
  text-align: center;
}

.uchida-hero__mark i {
  font-style: normal;
  font-size: clamp(28px, 3vw, 42px);
  color: rgba(17, 17, 17, 0.48);
}

.uchida-hero__sub {
  margin-top: 28px;
  font-size: 13px;
  color: #333;
}

.uchida-hero__mosaic {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 38% 34% 28%;
  gap: 12px;
  padding: 0 0 0 12px;
  overflow: hidden;
}

.uchida-hero__tile {
  overflow: hidden;
}

.uchida-hero__tile--1 {
  grid-column: 1 / 2;
}

.uchida-hero__tile--2 {
  grid-column: 2 / 3;
  grid-row: 1 / 3;
}

.uchida-hero__tile--3 {
  grid-column: 1 / 2;
  grid-row: 2 / 4;
}

.uchida-hero__tile--4 {
  grid-column: 2 / 3;
}

.uchida-news {
  height: 64px;
  overflow: hidden;
  border-bottom: 1px solid #171717;
  background: rgba(222, 223, 211, 0.95);
}

.uchida-news__track {
  display: flex;
  width: max-content;
  height: 100%;
  animation: uchidaTicker 42s linear infinite;
}

.uchida-news__item {
  display: flex;
  align-items: center;
  gap: 18px;
  min-width: 520px;
  padding: 0 26px;
  color: #111;
  font-size: 13px;
}

.uchida-news__item span {
  padding: 9px 14px;
  background: #000;
  color: #fff;
  font-size: 12px;
}

.uchida-news__item time {
  font-size: 12px;
  font-weight: 700;
}

.uchida-news__item b {
  font-weight: 600;
}

@keyframes uchidaTicker {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(-50%);
  }
}

.uchida-intro {
  position: relative;
  min-height: 720px;
  overflow: hidden;
  border-bottom: 1px solid rgba(17, 17, 17, 0.2);
}

.uchida-intro__side {
  position: absolute;
  left: 26px;
  top: 40px;
  writing-mode: vertical-rl;
  font-family: var(--font-ja);
  font-size: clamp(86px, 10vw, 150px);
  color: rgba(17, 17, 17, 0.06);
  line-height: 0.86;
}

.uchida-intro__circle {
  position: absolute;
  left: 20%;
  top: 130px;
  display: grid;
  place-items: center;
  width: 560px;
  height: 560px;
  border: 1px solid rgba(17, 17, 17, 0.08);
  border-radius: 50%;
  color: rgba(17, 17, 17, 0.08);
  font-size: 12px;
  text-align: center;
  animation: uchidaRotation 50s linear infinite;
}

@keyframes uchidaRotation {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.uchida-intro__copy {
  position: absolute;
  right: 8%;
  top: 188px;
  display: flex;
  gap: 58px;
  align-items: flex-start;
}

.uchida-vertical-title {
  display: grid;
  grid-template-columns: repeat(2, 56px);
  grid-auto-rows: 56px;
  border-top: 1px solid rgba(17, 17, 17, 0.58);
  border-left: 1px solid rgba(17, 17, 17, 0.58);
  font-family: var(--font-ja);
  font-size: 32px;
  line-height: 1;
}

.uchida-vertical-title span {
  display: grid;
  place-items: center;
  border-right: 1px solid rgba(17, 17, 17, 0.58);
  border-bottom: 1px solid rgba(17, 17, 17, 0.58);
}

.uchida-intro__copy > p:last-child {
  max-width: 330px;
  padding-top: 320px;
  font-size: 15px;
  line-height: 2.25;
  font-weight: 600;
}

.uchida-wide-photo {
  height: 420px;
  border-bottom: 1px solid #171717;
}

.uchida-detail {
  display: grid;
  grid-template-columns: 43% 57%;
  min-height: 1030px;
  border-bottom: 1px solid rgba(17, 17, 17, 0.2);
}

.uchida-detail__rail {
  position: sticky;
  top: 72px;
  align-self: start;
  justify-self: end;
  display: grid;
  grid-template-rows: 120px 1fr 48px;
  width: 192px;
  min-height: calc(100svh - 72px);
  border-left: 1px solid rgba(17, 17, 17, 0.18);
  border-right: 1px solid rgba(17, 17, 17, 0.18);
}

.uchida-detail__rail > span {
  display: grid;
  place-items: center;
  border-bottom: 1px solid rgba(17, 17, 17, 0.16);
  font-family: var(--font-ja);
  font-size: 13px;
}

.uchida-detail__rail h2 {
  align-self: center;
  display: grid;
  grid-template-columns: repeat(4, 48px);
  grid-auto-rows: 48px;
  border-top: 1px solid rgba(17, 17, 17, 0.28);
  border-left: 1px solid rgba(17, 17, 17, 0.28);
  font-family: var(--font-ja);
  font-size: 29px;
  font-weight: 400;
  line-height: 1;
}

.uchida-detail__rail h2 span {
  display: grid;
  place-items: center;
  border-right: 1px solid rgba(17, 17, 17, 0.28);
  border-bottom: 1px solid rgba(17, 17, 17, 0.28);
}

.uchida-detail__button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  background: #000;
  color: #fff;
  font-size: 13px;
}

.uchida-detail__items {
  padding: 130px 7vw 90px;
}

.uchida-detail__item {
  display: grid;
  grid-template-columns: 42% 1fr;
  gap: 42px;
  align-items: center;
  padding: 0 0 88px;
}

.uchida-detail__item:nth-child(even) {
  grid-template-columns: 1fr 42%;
}

.uchida-detail__item:nth-child(even) figure {
  order: 2;
}

.uchida-detail__item figure {
  aspect-ratio: 1;
}

.uchida-detail__item span {
  display: inline-grid;
  place-items: center;
  width: 58px;
  height: 58px;
  margin-bottom: 22px;
  border: 1px solid rgba(17, 17, 17, 0.45);
  border-radius: 50%;
  font-family: var(--font-ja);
}

.uchida-detail__item h3 {
  max-width: 400px;
  font-family: var(--font-ja);
  font-size: clamp(26px, 3.2vw, 42px);
  font-weight: 400;
  line-height: 1.5;
}

.uchida-detail__item p {
  max-width: 520px;
  margin-top: 26px;
  font-size: 15px;
  line-height: 2.1;
}

.uchida-works {
  padding-top: 74px;
  border-bottom: 1px solid rgba(17, 17, 17, 0.2);
}

.uchida-section-heading {
  position: relative;
  min-height: 260px;
  padding: 0 72px 48px;
}

.uchida-section-heading span {
  display: block;
  margin-bottom: 28px;
  font-family: var(--font-ja);
  font-size: 13px;
}

.uchida-section-heading h2 {
  font-family: var(--font-ja);
  font-size: clamp(34px, 4.4vw, 62px);
  font-weight: 400;
  line-height: 1.2;
}

.uchida-section-heading p {
  margin-top: 28px;
  font-size: 15px;
  line-height: 2;
}

.uchida-section-heading a {
  position: absolute;
  right: 72px;
  bottom: 62px;
  color: #111;
  font-size: 14px;
}

.uchida-work-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border-top: 1px solid rgba(17, 17, 17, 0.2);
}

.uchida-work-card {
  position: relative;
  min-height: 272px;
  overflow: hidden;
  color: #fff;
}

.uchida-work-card::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(0deg, rgba(0, 0, 0, 0.62), rgba(0, 0, 0, 0.05));
}

.uchida-work-card img {
  transition: transform 0.8s cubic-bezier(0.4, 0.4, 0, 1);
}

.uchida-work-card:hover img {
  transform: scale(1.06);
}

.uchida-work-card span,
.uchida-work-card time,
.uchida-work-card h3,
.uchida-work-card b {
  position: absolute;
  z-index: 1;
}

.uchida-work-card span {
  left: 28px;
  bottom: 70px;
  font-size: 13px;
}

.uchida-work-card time {
  left: 120px;
  bottom: 70px;
  font-size: 12px;
}

.uchida-work-card h3 {
  left: 28px;
  bottom: 28px;
  font-size: 18px;
  font-weight: 500;
}

.uchida-work-card b {
  right: 30px;
  bottom: 32px;
  font-size: 32px;
  font-weight: 300;
}

.uchida-story {
  padding: 120px 0 82px;
  background:
    radial-gradient(ellipse at 0% 20%, rgba(17, 17, 17, 0.12) 0 20%, transparent 21%),
    var(--uchida-paper);
  overflow: hidden;
}

.uchida-story__head {
  text-align: center;
}

.uchida-story__head span {
  font-size: 19px;
}

.uchida-story__head h2 {
  margin-top: 22px;
  font-family: var(--font-ja);
  font-size: clamp(34px, 4vw, 56px);
  font-weight: 400;
  line-height: 1.35;
}

.uchida-story__panel {
  display: grid;
  grid-template-columns: 58px repeat(3, minmax(260px, 1fr));
  max-width: 1024px;
  margin: 50px auto 0;
  border: 1px solid rgba(17, 17, 17, 0.28);
}

.uchida-story__tabs {
  display: grid;
  grid-template-rows: repeat(4, 56px);
  border-right: 1px solid rgba(17, 17, 17, 0.22);
  color: rgba(17, 17, 17, 0.48);
}

.uchida-story__tabs span {
  display: grid;
  place-items: center;
  border-bottom: 1px solid rgba(17, 17, 17, 0.12);
  font-family: var(--font-ja);
  font-size: 22px;
}

.uchida-story__episode {
  padding: 56px 38px 64px;
  border-right: 1px solid rgba(17, 17, 17, 0.16);
}

.uchida-story__episode:last-child {
  border-right: 0;
}

.uchida-story__episode span {
  display: block;
  writing-mode: vertical-rl;
  min-height: 92px;
  margin-bottom: 24px;
  font-family: var(--font-ja);
  font-size: 14px;
}

.uchida-story__episode h3 {
  font-family: var(--font-ja);
  font-size: 25px;
  font-weight: 400;
  line-height: 1.65;
}

.uchida-story__episode p {
  margin-top: 26px;
  font-size: 14px;
  line-height: 2.25;
}

.uchida-story__photos {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
  margin-top: 74px;
}

