/* --- Loading animation --- */
@keyframes fadeInUp {
  from {
    opacity: 1;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Counter animation */
.counter-animate {
  display: inline-block;
}

/* Image placeholder for development */
.img-placeholder {
  background: linear-gradient(135deg, var(--color-bg-gray) 0%, var(--color-border-light) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-muted);
  font-size: 14px;
  font-weight: var(--fw-medium);
  width: 100%;
  height: 100%;
  min-height: 200px;
}

/* Simulation page specific */
.sim-content {
  background:
    radial-gradient(1200px 500px at 15% -5%, rgba(245, 134, 0, 0.08), transparent 60%),
    radial-gradient(1000px 460px at 100% 0%, rgba(25, 42, 86, 0.08), transparent 58%),
    linear-gradient(180deg, #f8fafc 0%, #f4f7fb 100%);
}

.sim-intro {
  position: relative;
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 24px;
  padding: 28px;
  margin-bottom: 24px;
  border-radius: 18px;
  background: linear-gradient(125deg, #0d2246 0%, #1e3769 100%);
  color: #fff;
  overflow: hidden;
}

.sim-intro::after {
  content: "";
  position: absolute;
  width: 320px;
  height: 320px;
  right: -80px;
  top: -120px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(245, 134, 0, 0.45) 0%, rgba(245, 134, 0, 0) 70%);
  pointer-events: none;
}

.sim-intro__main {
  position: relative;
  z-index: 1;
}

.sim-intro__eyebrow {
  margin: 0 0 8px;
  font-family: var(--font-en);
  font-size: 12px;
  font-weight: var(--fw-bold);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.7);
}

.sim-intro__title {
  margin: 0;
  font-size: clamp(22px, 3.5vw, 32px);
  line-height: 1.35;
  font-weight: var(--fw-black);
}

.sim-intro__text {
  margin: 12px 0 0;
  font-size: 14px;
  line-height: 1.9;
  color: rgba(255, 255, 255, 0.86);
}

.sim-layout {
  display: grid;
  grid-template-columns: 300px 1fr;
  gap: 22px;
  align-items: start;
}

.sim-side {
  position: sticky;
  top: 96px;
}

.sim-side__panel {
  border: 1px solid #dce4ef;
  border-radius: 14px;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  padding: 18px;
  box-shadow: 0 14px 30px rgba(14, 34, 68, 0.08);
}

.sim-side__title {
  margin: 0;
  font-size: 16px;
  font-weight: var(--fw-bold);
  color: var(--color-primary);
}

.sim-side__text {
  margin: 8px 0 0;
  font-size: 13px;
  line-height: 1.7;
  color: var(--color-text-light);
}

.sim-progress {
  margin-top: 14px;
  padding-top: 12px;
  border-top: 1px dashed #d3dce8;
}

.sim-progress__head {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  font-size: 12px;
  color: var(--color-text-light);
}

.sim-progress__head strong {
  font-family: var(--font-en);
  color: var(--color-accent);
}

.sim-progress__bar {
  margin-top: 8px;
  width: 100%;
  height: 8px;
  border-radius: 999px;
  background: #e8eef7;
  overflow: hidden;
}

.sim-progress__bar span {
  display: block;
  height: 100%;
  width: 0%;
  border-radius: inherit;
  background: linear-gradient(90deg, #ff9a2f 0%, #f58600 100%);
  transition: width 0.35s ease;
}

.sim-side__meta {
  margin: 14px 0 0;
  display: grid;
  gap: 10px;
}

.sim-side__meta div {
  display: grid;
  gap: 2px;
  padding-top: 10px;
  border-top: 1px dashed #d3dce8;
}

.sim-side__meta dt {
  font-size: 11px;
  letter-spacing: 0.06em;
  color: var(--color-text-muted);
}

.sim-side__meta dd {
  margin: 0;
  font-size: 14px;
  font-weight: var(--fw-bold);
  color: var(--color-primary);
}

.sim-main {
  min-width: 0;
}

.sim-card {
  background: var(--color-white);
  border: 1px solid #dce4ef;
  border-radius: 14px;
  padding: 26px;
  margin-bottom: 24px;
  box-shadow: 0 12px 30px rgba(14, 34, 68, 0.08);
  transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
}

.sim-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 18px 36px rgba(14, 34, 68, 0.12);
  border-color: #c9d7ea;
}

.sim-card.active {
  border-color: var(--color-accent);
}

.sim-attention {
  background: #fff8e1;
  border: 1px solid #ffc107;
  border-radius: 10px;
  padding: 16px 18px;
  margin-bottom: 32px;
  font-size: 13px;
  color: #7b6100;
  text-align: center;
}

.sim-step-title {
  display: flex;
  align-items: baseline;
  gap: 10px;
  font-size: 18px;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 16px;
}

.sim-step-no {
  color: var(--color-accent);
  font-family: var(--font-en);
  font-weight: 900;
}

.sim-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

.tab-btn {
  border: 1px solid #d5deea;
  background: var(--color-white);
  border-radius: 999px;
  padding: 12px 16px;
  font-size: 13px;
  font-weight: var(--fw-medium);
  cursor: pointer;
  transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
}

.tab-btn.active {
  border-color: var(--color-accent);
  background: var(--color-accent-light);
  color: var(--color-accent);
}

.sim-option-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 12px;
}

.sim-option-grid--compact {
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
}

.sim-option-btn {
  border: 1px solid #d5deea;
  background: var(--color-white);
  border-radius: var(--radius);
  padding: 14px 16px;
  font-size: 14px;
  font-weight: var(--fw-medium);
  cursor: pointer;
  transition: border-color 0.2s ease, transform 0.2s ease, background 0.2s ease, color 0.2s ease;
  text-align: left;
}

.sim-option-btn:hover {
  border-color: rgba(245, 134, 0, 0.45);
  transform: translateY(-1px);
}

.sim-option-btn.active {
  border-color: var(--color-accent);
  background: var(--color-accent-light);
  color: var(--color-accent);
}

.sim-conditional {
  margin-top: 18px;
  padding-top: 18px;
  border-top: 1px dashed var(--color-border-light);
}

.sim-dimension-inputs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.sim-dimension {
  display: grid;
  grid-template-columns: 1fr;
}

.sim-input-group .form-label {
  margin-bottom: 8px;
}

.sim-inline {
  display: flex;
  align-items: center;
  gap: 10px;
}

.sim-unit {
  font-size: 14px;
  color: var(--color-text-light);
}

.sim-help {
  margin: 10px 0 0;
  font-size: 12px;
  color: var(--color-text-muted);
  line-height: 1.6;
}

.sim-actions {
  display: flex;
  justify-content: center;
  gap: 12px;
  margin-top: 20px;
}

.sim-radio-group {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 12px;
}

.sim-radio {
  display: none;
}

.sim-radio-label {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px 20px;
  border: 2px solid var(--color-border);
  border-radius: var(--radius);
  cursor: pointer;
  transition: var(--transition);
  font-size: 14px;
  font-weight: var(--fw-medium);
}

.sim-radio:checked + .sim-radio-label {
  border-color: var(--color-accent);
  background: var(--color-accent-light);
  color: var(--color-accent);
}

.sim-result {
  background:
    radial-gradient(700px 260px at 80% 0%, rgba(245, 134, 0, 0.22), transparent 60%),
    linear-gradient(140deg, #0e2244 0%, #172f5c 100%);
  color: var(--color-white);
  border-radius: 16px;
  padding: 40px;
  text-align: center;
  box-shadow: 0 20px 40px rgba(14, 34, 68, 0.22);
}

.sim-result__price {
  font-family: var(--font-en);
  font-size: 48px;
  font-weight: var(--fw-black);
  color: var(--color-accent);
}

.sim-result__unit {
  font-size: 18px;
  color: rgba(255,255,255,0.7);
}

.sim-result__kicker {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8px;
}

.sim-result__range {
  font-family: var(--font-en);
  font-size: 34px;
  font-weight: var(--fw-black);
  color: var(--color-accent);
  letter-spacing: 0.02em;
}

.sim-result__note {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 14px;
  line-height: 1.7;
}

.sim-breakdown {
  margin-top: 26px;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.18);
  border-radius: 14px;
  padding: 18px;
  text-align: left;
}

.price-details {
  background: rgba(255, 255, 255, 0.96);
  color: var(--color-text);
  border-radius: 12px;
  padding: 18px;
}

.detail-header {
  font-size: 14px;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 12px;
}

.work-details {
  padding: 14px 0;
  border-top: 1px solid var(--color-border-light);
}

.work-details h4 {
  margin: 0 0 10px;
  font-size: 15px;
  font-weight: 700;
  color: var(--color-primary);
}

.detail-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 12px;
  padding: 10px 0;
  border-top: 1px solid rgba(0, 0, 0, 0.06);
  align-items: baseline;
}

.detail-row:first-of-type {
  border-top: none;
}

.detail-label {
  font-size: 13px;
  color: var(--color-text);
  line-height: 1.6;
}

.detail-value {
  font-size: 13px;
  font-weight: 700;
  color: var(--color-primary);
  white-space: nowrap;
}

.subtotal-row .detail-value,
.total-row .detail-value {
  color: var(--color-accent);
}

.subtotal-row {
  margin-top: 6px;
  border-top: 1px dashed rgba(0, 0, 0, 0.12);
}

.total-row {
  margin-top: 10px;
  border-top: 2px solid rgba(0, 0, 0, 0.12);
}

.sim-mobile-calc {
  position: fixed;
  left: 50%;
  bottom: 18px;
  transform: translateX(-50%);
  z-index: 1200;
  display: none;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 48px;
  padding: 0 20px;
  border: none;
  border-radius: 999px;
  font-size: 14px;
  font-weight: var(--fw-bold);
  color: #fff;
  background: linear-gradient(135deg, #ff992f 0%, #f58600 100%);
  box-shadow: 0 14px 30px rgba(245, 134, 0, 0.34);
}

.sim-mobile-calc:hover {
  filter: brightness(1.03);
}

@media (max-width: 768px) {
  .sim-intro {
    grid-template-columns: 1fr;
    gap: 16px;
    padding: 22px;
    border-radius: 14px;
  }

  .sim-layout {
    grid-template-columns: 1fr;
    gap: 14px;
  }

  .sim-side {
    position: static;
  }

  .sim-side__panel {
    padding: 14px;
  }

  .sim-card {
    padding: 18px;
    border-radius: 12px;
  }

  .sim-tabs {
    grid-template-columns: 1fr;
  }

  .sim-dimension-inputs {
    grid-template-columns: 1fr;
  }

  .sim-option-grid,
  .sim-option-grid--compact {
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .sim-actions .btn {
    width: 100%;
  }

  .sim-actions {
    flex-direction: column;
  }

  .sim-result {
    padding: 22px 16px;
  }

  .detail-row {
    grid-template-columns: 1fr;
    gap: 4px;
  }

  .sim-mobile-calc {
    display: inline-flex;
  }
}

@media (prefers-reduced-motion: reduce) {
  .sim-card,
  .sim-option-btn,
  .sim-progress__bar span {
    transition: none;
  }
}

/* --- Recruit specific --- */
.recruit-hero {
  background: var(--service-hero-bg-image, url('/images/service-hero-bg.png')) center / cover no-repeat;
}

.recruit-values {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.recruit-value-card {
  text-align: center;
  padding: 40px 24px;
  background: var(--color-white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.recruit-value-card__icon {
  font-size: 48px;
  color: var(--color-accent);
  margin-bottom: 16px;
}

.recruit-value-card__title {
  font-size: 18px;
  font-weight: var(--fw-bold);
  color: var(--color-primary);
  margin-bottom: 12px;
}

.recruit-value-card__text {
  font-size: 14px;
  color: var(--color-text-light);
  line-height: 1.8;
}

@media (max-width: 768px) {
  .recruit-values {
    grid-template-columns: 1fr;
  }
}

/* --- Tag list for works filter --- */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tag {
  display: inline-block;
  padding: 4px 12px;
  font-size: 12px;
  border-radius: 50px;
  background: var(--color-bg-light);
  color: var(--color-text-light);
  font-weight: var(--fw-medium);
}

/* --- Dive Survey LP specific --- */
.dive-hero {
  background: var(--service-hero-bg-image, url('/images/service-hero-bg.png')) center / cover no-repeat;
}

.dive-feature {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
}

.dive-feature-card {
  text-align: center;
  padding: 40px 24px;
  background: var(--color-white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  transition: var(--transition);
}

.dive-feature-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
}

.dive-feature-card__icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.dive-feature-card__title {
  font-size: 18px;
  font-weight: var(--fw-bold);
  color: var(--color-primary);
  margin-bottom: 8px;
}

.dive-feature-card__text {
  font-size: 14px;
  color: var(--color-text-light);
  line-height: 1.8;
}

@media (max-width: 768px) {
  .dive-feature {
    grid-template-columns: 1fr;
  }
}

/* --- Large-scale-repair pillars --- */
.lsr-pillars {
  margin: 30px 0;
  padding: 28px;
  border-top: 3px solid var(--color-accent);
  border-radius: 16px;
  background:
    linear-gradient(120deg, rgba(255, 124, 0, 0.08) 0%, rgba(255, 124, 0, 0) 42%),
    linear-gradient(180deg, #fafbfd 0%, #f3f6f9 100%);
}

.lsr-pillars__label {
  margin-bottom: 18px;
  font-family: var(--font-en);
  font-size: 12px;
  letter-spacing: 0.14em;
  font-weight: var(--fw-bold);
  color: var(--color-accent);
  text-transform: uppercase;
}

.lsr-pillars__list {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0;
}

.lsr-pillars__item {
  padding: 8px 24px 4px;
}

.lsr-pillars__item + .lsr-pillars__item {
  border-left: 1px solid rgba(14, 28, 52, 0.16);
}

.lsr-pillars__num {
  margin-bottom: 10px;
  font-family: var(--font-en);
  font-size: 30px;
  font-weight: var(--fw-black);
  line-height: 1;
  color: rgba(14, 28, 52, 0.14);
}

.lsr-pillars__title {
  margin: 0 0 10px;
  font-size: 20px;
  font-weight: var(--fw-bold);
  line-height: 1.4;
  color: var(--color-primary);
}

.lsr-pillars__text {
  margin: 0;
  font-size: 14px;
  line-height: 1.9;
  color: var(--color-text-light);
}

@media (max-width: 1024px) {
  .lsr-pillars {
    padding: 22px;
  }

  .lsr-pillars__title {
    font-size: 18px;
  }
}

@media (max-width: 768px) {
  .lsr-pillars__list {
    grid-template-columns: 1fr;
    gap: 18px;
  }

  .lsr-pillars__item {
    padding: 4px 0 0;
  }

  .lsr-pillars__item + .lsr-pillars__item {
    border-left: 0;
    border-top: 1px solid rgba(14, 28, 52, 0.16);
    padding-top: 18px;
  }

  .lsr-pillars__num {
