/* --- Fixed CTA (追従CTA) --- */
.fixed-cta {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  z-index: 900;
  transform: translateY(100%);
  transition: var(--transition);
}

.fixed-cta.visible {
  transform: translateY(0);
}

.fixed-cta__inner {
  display: none;
}

/* PC Float Button */
.fixed-cta__float {
  position: fixed;
  bottom: 96px;
  right: 30px;
  z-index: 900;
  transform: translateY(100px);
  opacity: 1;
  transition: var(--transition);
}

.fixed-cta__float.visible {
  transform: translateY(0);
  opacity: 1;
}

.fixed-cta__contact-card {
  position: relative;
  overflow: hidden;
  width: 304px;
  border-radius: 16px;
  background: linear-gradient(135deg, #ff8b1a 0%, #ef6a00 100%);
  color: var(--color-white);
  box-shadow: 0 12px 32px rgba(20, 37, 64, 0.32);
  padding: 11px 16px 12px;
  display: block;
  text-decoration: none;
  transition: transform var(--transition), box-shadow var(--transition);
}

.fixed-cta__contact-card::after {
  content: "";
  position: absolute;
  top: -30%;
  left: -36%;
  width: 28%;
  height: 160%;
  background: linear-gradient(
    120deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.2) 35%,
    rgba(255, 255, 255, 0.82) 50%,
    rgba(255, 255, 255, 0.2) 65%,
    rgba(255, 255, 255, 0) 100%
  );
  transform: translateX(-220%) skewX(-24deg);
  opacity: 0;
  pointer-events: none;
}

.fixed-cta__contact-sub {
  display: block;
  text-align: center;
  font-size: 12px;
  font-weight: var(--fw-bold);
  letter-spacing: 0.02em;
  margin-bottom: 5px;
}

.fixed-cta__contact-main {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  font-size: 18px;
  font-weight: var(--fw-black);
  line-height: 1.05;
}

.fixed-cta__contact-icon {
  width: 37px;
  height: 37px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  border: 2px solid rgba(255, 255, 255, 0.8);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 18px;
}

.fixed-cta__contact-arrow {
  font-size: 27px;
  line-height: 1;
}

@keyframes fixedCtaShine {
  0% {
    transform: translateX(-220%) skewX(-24deg);
    opacity: 0;
  }

  12% {
    opacity: 1;
  }

  100% {
    transform: translateX(420%) skewX(-24deg);
    opacity: 0;
  }
}

@media (hover: hover) and (pointer: fine) {
  .fixed-cta__contact-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 36px rgba(20, 37, 64, 0.36);
  }

  .fixed-cta__contact-card:hover::after {
    animation: fixedCtaShine 960ms ease-out infinite;
  }
}

/* --- Footer --- */
.footer {
  background: var(--color-primary-dark);
  color: var(--color-white);
  padding: 80px 0 0;
}

.footer__inner {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr 1fr;
  gap: 40px;
  margin-bottom: 60px;
}

.footer__brand {
  margin-bottom: 20px;
}

.footer__logo {
  font-size: 20px;
  font-weight: var(--fw-bold);
  margin-bottom: 4px;
}

.footer__logo-sub {
  font-size: 11px;
  color: rgba(255,255,255,0.5);
  letter-spacing: 0.1em;
}

.footer__company-info {
  font-size: 13px;
  color: rgba(255,255,255,0.6);
  line-height: 2;
  margin-top: 16px;
}

.footer__nav-title {
  font-size: 14px;
  font-weight: var(--fw-bold);
  margin-bottom: 20px;
  padding-bottom: 10px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}

.footer__nav-link {
  display: block;
  font-size: 13px;
  color: rgba(255,255,255,0.6);
  padding: 6px 0;
  transition: var(--transition);
}

.footer__nav-link:hover {
  color: var(--color-accent);
}

.footer__bottom {
  border-top: 1px solid rgba(255,255,255,0.08);
  padding: 24px 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.footer__copyright {
  font-size: 12px;
  color: rgba(255,255,255,0.72);
  font-family: var(--font-en);
}

.footer__bottom-links {
  display: flex;
  gap: 24px;
}

.footer__bottom-link {
  font-size: 12px;
  color: rgba(255,255,255,0.72);
}

.footer__bottom-link:hover {
  color: #ffffff;
}

/* --- Breadcrumb --- */
.breadcrumb {
  display: block;
  position: relative;
  z-index: 2;
  margin-top: var(--header-height);
  padding: 16px 0;
  background: var(--color-bg-light);
  border-bottom: 1px solid var(--color-border-light);
}

.breadcrumb__list {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: var(--color-text-muted);
  flex-wrap: wrap;
}

.breadcrumb__link {
  color: var(--color-text-light);
}

.breadcrumb__link:hover {
  color: var(--color-accent);
}

.breadcrumb__separator {
  font-size: 10px;
}

/* --- Page Hero --- */
.page-hero {
  background: var(--service-hero-bg-image, url('/images/service-hero-bg.png')) center / cover no-repeat;
  padding: 140px 0 80px;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.page-hero::before {
  display: none;
}

.page-hero--no-deco::before {
  display: none;
}

.page-hero__label {
  font-family: var(--font-en);
  font-size: 13px;
  font-weight: var(--fw-semibold);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: 12px;
}

.page-hero__title {
  font-size: 36px;
  font-weight: var(--fw-bold);
  color: var(--color-white);
  line-height: 1.4;
}

.page-hero__description {
  font-size: 15px;
  color: rgba(255,255,255,0.7);
  margin-top: 16px;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

/* --- Content Sections --- */
.content-section {
  padding: var(--section-padding);
}

.content-section--gray {
  background: var(--color-bg-light);
}

/* --- Column (Blog) Cards --- */
.column-layout {
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: 36px;
  align-items: start;
}

.column-sidebar {
  position: sticky;
  top: calc(var(--header-height) + 24px);
  padding: 24px;
  border-radius: 14px;
  background: linear-gradient(180deg, #f5f8fc 0%, #eef3f8 100%);
  border: 1px solid rgba(18, 41, 71, 0.08);
}

.column-sidebar__title {
  margin: 0 0 8px;
  font-size: 20px;
  font-weight: var(--fw-bold);
  color: var(--color-primary);
}

.column-sidebar__text {
  margin: 0 0 20px;
  font-size: 13px;
  line-height: 1.8;
  color: var(--color-text-light);
}

.column-filter {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.column-filter__btn {
  width: 100%;
  padding: 12px 14px;
  border: 1px solid rgba(18, 41, 71, 0.15);
  border-radius: 10px;
  background: var(--color-white);
  color: var(--color-primary);
  font-size: 14px;
  font-weight: var(--fw-medium);
  text-align: left;
  cursor: pointer;
  transition: var(--transition);
}

.column-filter__btn:hover {
  border-color: var(--color-accent);
  transform: translateX(2px);
}

.column-filter__btn.active {
  background: var(--color-primary);
  border-color: var(--color-primary);
  color: var(--color-white);
}

.column-list {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.column-card {
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: 20px;
  padding: 24px;
  background: var(--color-white);
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
  transition: var(--transition);
  align-items: center;
}

.column-card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}

.column-card__image {
  aspect-ratio: 16/10;
  border-radius: var(--radius);
  overflow: hidden;
}

.column-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.column-card__body {}

.column-card__meta {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}

.column-card__date {
  font-family: var(--font-en);
  font-size: 12px;
  color: var(--color-text-muted);
  margin-bottom: 0;
}

.column-card__category {
  display: inline-flex;
  align-items: center;
  padding: 2px 10px;
  border-radius: 999px;
  background: rgba(255, 124, 0, 0.12);
  color: #a95400;
  font-size: 11px;
  font-weight: var(--fw-bold);
}

.column-card__title {
  font-size: 16px;
  font-weight: var(--fw-bold);
  color: var(--color-primary);
  line-height: 1.5;
  margin-bottom: 8px;
}

.column-card__excerpt {
  font-size: 13px;
  color: var(--color-text-light);
  line-height: 1.7;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* --- Form --- */
.form-group {
  margin-bottom: 24px;
}

.form-label {
  display: block;
  font-size: 14px;
  font-weight: var(--fw-bold);
  color: var(--color-primary);
  margin-bottom: 8px;
}

.form-label .required {
  display: inline-block;
  background: var(--color-accent);
  color: var(--color-white);
  font-size: 10px;
  padding: 2px 8px;
  border-radius: 3px;
  margin-left: 8px;
  font-weight: var(--fw-medium);
}

.form-input,
.form-textarea,
.form-select {
  width: 100%;
  padding: 14px 18px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  font-size: 15px;
  transition: var(--transition);
  background: var(--color-white);
}

.form-input:focus,
.form-textarea:focus,
.form-select:focus {
  outline: none;
  border-color: var(--color-accent);
  box-shadow: 0 0 0 3px rgba(232, 116, 12, 0.1);
}

.form-textarea {
  min-height: 160px;
  resize: vertical;
}

/* --- Table --- */
.info-table {
  width: 100%;
  border-collapse: collapse;
}

.info-table th,
.info-table td {
  padding: 16px 20px;
  border-bottom: 1px solid var(--color-border-light);
  font-size: 14px;
  text-align: left;
  vertical-align: top;
}

.info-table th {
  background: var(--color-bg-light);
  font-weight: var(--fw-bold);
  color: var(--color-primary);
  width: 200px;
  white-space: nowrap;
}

/* --- Pagination --- */
.pagination {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-top: 60px;
}

.pagination__link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  font-family: var(--font-en);
  font-size: 14px;
  font-weight: var(--fw-medium);
  color: var(--color-text);
  transition: var(--transition);
}

.pagination__link:hover,
.pagination__link.active {
  background: var(--color-primary);
  color: var(--color-white);
  border-color: var(--color-primary);
}

/* --- Animations (Scroll Reveal) --- */
.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1), transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}

.reveal.revealed {
  opacity: 1;
  transform: translateY(0);
}

.reveal--delay-1 { transition-delay: 0.1s; }
.reveal--delay-2 { transition-delay: 0.2s; }
.reveal--delay-3 { transition-delay: 0.3s; }
.reveal--delay-4 { transition-delay: 0.4s; }

/* --- Article Content --- */
.article-content {
  max-width: 800px;
  margin: 0 auto;
}

.article-content h2 {
  font-size: 24px;
  font-weight: var(--fw-bold);
  color: var(--color-primary);
  margin: 48px 0 20px;
  padding-left: 16px;
  border-left: 4px solid var(--color-accent);
}

.article-content h3 {
  font-size: 20px;
  font-weight: var(--fw-bold);
  color: var(--color-primary);
  margin: 36px 0 16px;
}

.article-content p {
  margin-bottom: 20px;
  line-height: 2;
}

.article-content ul, .article-content ol {
  margin: 20px 0;
  padding-left: 24px;
}

.article-content li {
  list-style: disc;
  margin-bottom: 8px;
  line-height: 1.8;
}

.article-content ol li {
  list-style: decimal;
}

/* --- Company FAQ --- */
.company-faq {
  display: grid;
  gap: 14px;
}

.company-faq__item {
  border: 1px solid #d4dce9;
  border-radius: 14px;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  box-shadow: 0 6px 18px rgba(17, 38, 75, 0.06);
  overflow: hidden;
}

.company-faq__question {
  position: relative;
  list-style: none;
  cursor: pointer;
  padding: 18px 58px 18px 22px;
  font-size: 18px;
  font-weight: var(--fw-bold);
  line-height: 1.5;
  color: var(--color-primary);
}

.company-faq__question::-webkit-details-marker {
  display: none;
}

.company-faq__question::before,
.company-faq__question::after {
  content: "";
  position: absolute;
  right: 24px;
  top: 50%;
  width: 14px;
  height: 2px;
  background: #f58600;
  transition: transform 0.2s ease;
}

.company-faq__question::after {
  transform: translateY(-50%) rotate(90deg);
}

.company-faq__question::before {
  transform: translateY(-50%);
}

.company-faq__item[open] .company-faq__question::after {
  transform: translateY(-50%) rotate(0deg);
}

.company-faq__answer {
  margin: 0;
  padding: 0 22px 18px;
  font-size: 15px;
  line-height: 1.9;
  color: #30486f;
}

/* --- Back to Top --- */
.back-to-top {
  position: fixed;
  bottom: 30px;
  right: 30px;
  width: 48px;
  height: 48px;
  background: var(--color-primary);
  color: var(--color-white);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  box-shadow: var(--shadow-md);
  opacity: 1;
  visibility: hidden;
  transition: var(--transition);
  z-index: 800;
  cursor: pointer;
}

.back-to-top.visible {
  opacity: 1;
  visibility: visible;
}

.back-to-top:hover {
  background: var(--color-accent);
  transform: translateY(-4px);
}

