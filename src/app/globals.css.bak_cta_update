.cookie-consent-banner {
  position: fixed;
  left: 16px;
  right: 16px;
  bottom: 16px;
  z-index: 9999;
  background: #1a2744;
  color: #fff;
  border-radius: 12px;
  padding: 10px 12px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.cookie-consent-banner p {
  margin: 0;
  font-size: 13px;
  line-height: 1.5;
}

.cookie-consent-banner__buttons {
  display: flex;
  gap: 8px;
  justify-content: flex-end;
}

.cookie-consent-banner button {
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.45);
  color: #fff;
  border-radius: 8px;
  padding: 6px 12px;
  font-size: 13px;
  cursor: pointer;
  white-space: nowrap;
}

.cookie-consent-banner button.primary {
  background: #e8740c;
  border: none;
  font-weight: 700;
}

@media (min-width: 768px) {
  .cookie-consent-banner {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding: 8px 16px;
    gap: 16px;
  }
  
  .cookie-consent-banner__buttons {
    margin-top: 0;
  }
}

