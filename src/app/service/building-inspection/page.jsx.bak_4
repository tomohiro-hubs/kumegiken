          margin-bottom: 48px;
        }
        .bi-faq-item {
          margin-bottom: 24px;
          border-bottom: 1px dashed var(--color-border);
          padding-bottom: 20px;
        }
        .bi-faq-item:last-child {
          margin-bottom: 0;
          border-bottom: none;
          padding-bottom: 0;
        }
        .bi-faq-item h5 {
          margin: 0 0 8px 0;
          font-size: 15px;
          font-weight: 700;
          color: var(--color-primary);
          display: flex;
          gap: 8px;
        }
        .bi-faq-item h5::before {
          content: 'Q';
          color: var(--color-accent);
          font-weight: 900;
        }
        .bi-faq-item p {
          margin: 0;
          font-size: 13px;
          color: var(--color-text-light);
          line-height: 1.7;
          display: flex;
          gap: 8px;
        }
        .bi-faq-item p::before {
          content: 'A';
          color: var(--color-primary);
          font-weight: 900;
        }

        /* Responsive */
        @media (max-width: 991px) {
          .bi-building-grid {
            grid-template-columns: repeat(2, 1fr);
          }
        }
        @media (max-width: 768px) {
          .bi-intro-row {
            grid-template-columns: 1fr;
            gap: 20px;
          }
          .bi-tech-grid {
            grid-template-columns: 1fr;
          }
          .bi-bg-grid {
            grid-template-columns: 1fr;
            gap: 16px;
          }
          .bi-report-box {
            grid-template-columns: 1fr;
            gap: 12px;
          }
          .bi-flow-grid {
            grid-template-columns: 1fr;
          }
          .bi-bg-section {
            padding: 30px 20px;
          }
        }
      `}} />
    </main>
  );
}
