          margin-top: 55px;
          margin-bottom: 24px;
          border-bottom: 2px solid var(--color-border-light);
          padding-bottom: 12px;
        }
        .lsr-section-title__en {
          display: block;
          font-size: 11px;
          color: var(--color-accent);
          font-weight: 700;
          letter-spacing: 0.15em;
          text-transform: uppercase;
        }
        .lsr-section-title h3 {
          margin: 4px 0 0 0;
          font-size: 22px;
          color: var(--color-primary);
          font-weight: 800;
          letter-spacing: 0.02em;
        }

        /* Tech Grid */
        .bi-tech-grid {
          display: grid;
          grid-template-columns: repeat(2, 1fr);
          gap: 20px;
        }
        .bi-tech-card {
          background: #fff;
          border: 1px solid var(--color-border);
          border-radius: 12px;
          padding: 24px;
          display: flex;
          gap: 16px;
          transition: border-color 0.3s, box-shadow 0.3s;
        }
        .bi-tech-card:hover {
          border-color: var(--color-accent);
          box-shadow: 0 8px 24px rgba(0,0,0,0.04);
        }
        .bi-tech-card__icon {
          font-size: 28px;
          color: var(--color-accent);
          flex-shrink: 0;
          margin-top: 4px;
        }
        .bi-tech-card__body h4 {
          margin: 0 0 8px 0;
          font-size: 16px;
          font-weight: 700;
          color: var(--color-primary);
        }
        .bi-tech-card__body p {
          margin: 0;
          font-size: 13px;
          color: var(--color-text-light);
          line-height: 1.65;
        }

        /* アドバイスセクション（購入・売却） */
        .bi-advice-section {
          margin: 56px 0;
        }
        .bi-advice-grid {
          display: grid;
          grid-template-columns: repeat(2, 1fr);
          gap: 32px;
          margin-top: 32px;
        }
        .bi-advice-card {
          background: #fff;
          border: 1px solid var(--color-border);
          border-radius: 16px;
          padding: 32px;
          box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
          transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
        }
        .bi-advice-card:hover {
          transform: translateY(-4px);
          box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
          border-color: var(--color-accent);
        }
        .bi-advice-card__header {
          display: flex;
          align-items: center;
          gap: 16px;
          margin-bottom: 20px;
        }
        .bi-advice-card__icon-wrapper {
          width: 44px;
          height: 44px;
          border-radius: 50%;
          background: var(--color-accent-light);
          color: var(--color-accent);
          display: flex;
          align-items: center;
          justify-content: center;
          font-size: 18px;
          flex-shrink: 0;
        }
        .bi-advice-card__header h4 {
          margin: 0;
          font-size: 17px;
          font-weight: 800;
          color: var(--color-primary);
        }
        .bi-advice-card__list {
          margin: 0;
          padding: 0;
          list-style: none;
        }
        .bi-advice-card__list li {
          font-size: 13.5px;
          color: var(--color-text-light);
          line-height: 1.7;
          margin-bottom: 12px;
          position: relative;
          padding-left: 20px;
        }
        .bi-advice-card__list li::before {
          content: '✓';
          color: var(--color-accent);
          font-weight: bold;
          position: absolute;
          left: 0;
          top: 0;
        }
        .bi-advice-card__list li:last-child {
          margin-bottom: 0;
        }

        /* Report Box */
        .bi-report-box {
          background: var(--color-bg-light);
          border-radius: 12px;
          padding: 24px 30px;
          margin-bottom: 48px;
          display: grid;
          grid-template-columns: repeat(2, 1fr);
          gap: 16px 30px;
          border: 1px solid var(--color-border-light);
        }
        .bi-report-box__item {
          display: flex;
          align-items: flex-start;
          gap: 12px;
        }
        .bi-report-box__item i {
          font-size: 18px;
          color: var(--color-accent);
          margin-top: 2px;
        }
        .bi-report-box__item span {
          font-size: 14px;
          color: var(--color-text);
          line-height: 1.6;
        }

        /* Flow Grid */
        .bi-flow-grid {
          display: grid;
          grid-template-columns: repeat(3, 1fr);
          gap: 20px;
          margin-bottom: 48px;
        }
        .bi-flow-card {
          background: #fff;
          border: 1px solid var(--color-border);
          border-radius: 12px;
          padding: 28px 20px;
          text-align: center;
          position: relative;
          transition: transform 0.3s;
        }
        .bi-flow-card:hover {
          transform: translateY(-4px);
        }
        .bi-flow-card__step {
          display: inline-block;
          background: var(--color-primary);
          color: #fff;
          font-size: 11px;
          font-weight: 700;
          padding: 4px 10px;
          border-radius: 4px;
          margin-bottom: 16px;
        }
        .bi-flow-card h4 {
          margin: 0 0 10px 0;
          font-size: 16px;
          font-weight: 700;
          color: var(--color-primary);
        }
        .bi-flow-card p {
          margin: 0;
          font-size: 13px;
          color: var(--color-text-light);
          line-height: 1.6;
        }

        /* FAQ Block */
        .bi-faq-block {
          background: #fff;
          border: 1px solid var(--color-border);
          border-radius: 12px;
          padding: 30px;
          margin-bottom: 48px;
        }
        .bi-faq-item {
          margin-bottom: 24px;
          border-bottom: 1px dashed var(--color-border);
          padding-bottom: 20px;
        }
        .bi-faq-item:last-child {
          margin-bottom: 0;
          border-bottom: none;
          padding-bottom: 0;
        }
        .bi-faq-item h5 {
          margin: 0 0 8px 0;
          font-size: 15px;
          font-weight: 700;
          color: var(--color-primary);
          display: flex;
          gap: 8px;
        }
        .bi-faq-item h5::before {
          content: 'Q';
          color: var(--color-accent);
          font-weight: 900;
        }
        .bi-faq-item p {
          margin: 0;
          font-size: 13px;
          color: var(--color-text-light);
          line-height: 1.7;
          display: flex;
          gap: 8px;
        }
        .bi-faq-item p::before {
          content: 'A';
          color: var(--color-primary);
          font-weight: 900;
        }

        /* Responsive */
        @media (max-width: 991px) {
          .bi-reasons-grid {
            grid-template-columns: repeat(2, 1fr);
          }
        }
        @media (max-width: 768px) {
          .bi-intro-row {
            grid-template-columns: 1fr;
            gap: 20px;
          }
          .bi-reasons-grid {
            grid-template-columns: 1fr;
            gap: 16px;
          }
          .bi-reasons-section {
            padding: 30px 20px;
            margin: 40px 0;
          }
          .bi-insurance-banner-wrapper {
            flex-direction: column;
            min-height: auto;
            background: #fff5eb;
          }
          .bi-insurance-banner-image {
            position: static;
            height: 200px;
          }
          .bi-insurance-banner-content {
            position: static;
            max-width: 100%;
            margin: 0;
            background: transparent;
            box-shadow: none;
            backdrop-filter: none;
            padding: 24px 20px;
          }
          .bi-insurance-banner-title {
            font-size: 18px;
          }
          .bi-tech-grid {
            grid-template-columns: 1fr;
          }
          .bi-advice-grid {
            grid-template-columns: 1fr;
            gap: 20px;
          }
          .bi-advice-card {
            padding: 24px;
          }
          .bi-report-box {
            grid-template-columns: 1fr;
            gap: 12px;
          }
          .bi-flow-grid {
            grid-template-columns: 1fr;
          }
        }
      `}} />
    </main>
  );
}
